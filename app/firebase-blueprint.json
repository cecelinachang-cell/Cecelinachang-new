{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product in the catalog",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the product"
        },
        "price": {
          "type": "number",
          "description": "The price of the product"
        },
        "description": {
          "type": "string",
          "description": "The description of the product"
        },
        "imageUrl": {
          "type": "string",
          "description": "The URL of the product image"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the product was created"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the product was last updated"
        }
      },
      "required": ["name", "price", "description", "imageUrl", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "A collection of products"
    }
  }
}
