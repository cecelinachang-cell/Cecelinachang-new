rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "cecelinachang2@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'description', 'imageUrl', 'createdAt', 'updatedAt']) &&
             data.keys().hasOnly(['name', 'price', 'description', 'imageUrl', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.description is string && data.description.size() < 5000 &&
             data.imageUrl is string && (data.imageUrl.matches("^https://.*") || data.imageUrl.matches("^http://.*")) && data.imageUrl.size() < 1000 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /products/{productId} {
      allow read: if true; // Publicly readable catalog
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data) && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }
  }
}
