# DeepSeek API key. Keep this server-side; do not use the NEXT_PUBLIC_ prefix.
DEEPSEEK_API_KEY="YOUR_DEEPSEEK_API_KEY"

# NEXT_PUBLIC_SUPABASE_URL: URL to your Supabase project (Project settings -> API -> URL)
NEXT_PUBLIC_SUPABASE_URL="YOUR_SUPABASE_URL"

# NEXT_PUBLIC_SUPABASE_ANON_KEY: Public anonymous key for your Supabase project (Project settings -> API -> anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
